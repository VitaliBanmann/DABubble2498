[debug] [2026-04-15T21:04:22.797Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/da-bubble-da44d/rulesets {"name":"projects/da-bubble-da44d/rulesets/26040100-be07-4e01-ae33-2da2743206fc","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function isAnonymous() {\n      return isSignedIn()\n        && request.auth.token.firebase.sign_in_provider == \"anonymous\";\n    }\n\n    function isRegularUser() {\n      return isSignedIn() && !isAnonymous();\n    }\n\n    function hasField(data, field) {\n      return data.keys().hasAny([field]);\n    }\n\n    function isPublicChannelId(channelId) {\n      return channelId in ['allgemein', 'entwicklerteam'];\n    }\n\n    function hasMembersList(data) {\n      return hasField(data, 'members') && data.members is list;\n    }\n\n    function hasMemberIdsList(data) {\n      return hasField(data, 'memberIds') && data.memberIds is list;\n    }\n\n    function hasAdminsList(data) {\n      return !hasField(data, 'admins') || data.admins is list;\n    }\n\n    function isChannelMemberByData(data) {\n      return (\n        hasMembersList(data)\n        && request.auth.uid in data.members\n      ) || (\n        hasMemberIdsList(data)\n        && request.auth.uid in data.memberIds\n      );\n    }\n\n    function canReadChannelDoc(channelId, data) {\n      return isPublicChannelId(channelId) || isChannelMemberByData(data);\n    }\n\n    function isChannelOwner(data) {\n      return hasField(data, 'createdBy')\n        && data.createdBy is string\n        && data.createdBy == request.auth.uid;\n    }\n\n    function isChannelAdmin(data) {\n      return hasField(data, 'admins')\n        && data.admins is list\n        && request.auth.uid in data.admins;\n    }\n\n    function canManageChannel(data) {\n      return isChannelOwner(data) || isChannelAdmin(data);\n    }\n\n    function validChannelRoleLists(data) {\n      return hasMembersList(data)\n        && hasAdminsList(data)\n        && data.createdBy is string\n        && (\n          !hasField(data, 'memberIds')\n          || data.memberIds is list\n        );\n    }\n\n    function isMemberOnlyChannelUpdate() {\n      return request.resource.data\n        .diff(resource.data)\n        .changedKeys()\n        .hasOnly(['members', 'memberIds', 'updatedAt']);\n    }\n\n    function conversationIdFor(firstUid, secondUid) {\n      return firstUid < secondUid\n        ? firstUid + '__' + secondUid\n        : secondUid + '__' + firstUid;\n    }\n\n    function isConversationParticipant(conversationId) {\n      return conversationId is string\n        && conversationId.matches(\n          '^' + request.auth.uid + '__[^_].*$|^[^_].*__' + request.auth.uid + '$'\n        );\n    }\n\n    function isDirectMessage(data) {\n      return hasField(data, 'receiverId')\n        && hasField(data, 'conversationId')\n        && !hasField(data, 'channelId');\n    }\n\n    function isChannelMessage(data) {\n      return hasField(data, 'channelId')\n        && !hasField(data, 'receiverId')\n        && !hasField(data, 'conversationId');\n    }\n\n    function channelDoc(channelId) {\n      return get(/databases/$(database)/documents/channels/$(channelId));\n    }\n\n    function channelExists(channelId) {\n      return exists(/databases/$(database)/documents/channels/$(channelId));\n    }\n\n    function canReadDirectMessage(data) {\n      return (\n        hasField(data, 'senderId')\n        && hasField(data, 'receiverId')\n        && (\n          request.auth.uid == data.senderId\n          || request.auth.uid == data.receiverId\n        )\n      ) || (\n        hasField(data, 'conversationId')\n        && isConversationParticipant(data.conversationId)\n      );\n    }\n\n    function canReadChannelMessage(data) {\n      return hasField(data, 'channelId')\n        && channelExists(data.channelId)\n        && canReadChannelDoc(\n          data.channelId,\n          channelDoc(data.channelId).data\n        );\n    }\n\n    function canReadMessage(data) {\n      return canReadDirectMessage(data) || canReadChannelMessage(data);\n    }\n\n    function messageDoc(messageId) {\n      return get(/databases/$(database)/documents/messages/$(messageId));\n    }\n\n    function messageExists(messageId) {\n      return exists(/databases/$(database)/documents/messages/$(messageId));\n    }\n\n    function canReadThreadParent(messageId) {\n      return messageExists(messageId)\n        && canAccessThreadParent(messageDoc(messageId).data);\n    }\n\n    function canAccessThreadParent(parentData) {\n      return (\n        isChannelMessage(parentData)\n        && canReadChannelMessage(parentData)\n      ) || (\n        isDirectMessage(parentData)\n        && parentData.senderId is string\n        && parentData.receiverId is string\n        && (\n          request.auth.uid == parentData.senderId\n          || request.auth.uid == parentData.receiverId\n        )\n      );\n    }\n\n    function canCreateThreadMessage(messageId, data) {\n      return messageExists(messageId)\n        && canAccessThreadParent(messageDoc(messageId).data)\n        && data.senderId == request.auth.uid\n        && data.text is string\n        && data.text.size() > 0\n        && data.timestamp is timestamp;\n    }\n\n    function isValidInboxState(data, contextId) {\n      return data.contextId == contextId\n        && data.contextType is string\n        && data.contextType in ['channel', 'dm']\n        && data.targetId is string\n        && data.targetId.size() > 0\n        && data.lastReadAt is timestamp\n        && data.updatedAt is timestamp;\n    }\n\n    function validMentions(data) {\n      return !hasField(data, 'mentions')\n        || data.mentions is list;\n    }\n\n    function validAttachments(data) {\n      return !hasField(data, 'attachments')\n        || data.attachments is list;\n    }\n\n    function hasMessageBody(data) {\n      return data.text.size() > 0\n        || (\n          hasField(data, 'attachments')\n          && data.attachments is list\n          && data.attachments.size() > 0\n        );\n    }\n\n    function canCreateDirectMessage(data) {\n      return isDirectMessage(data)\n        && data.senderId == request.auth.uid\n        && data.receiverId is string\n        && data.receiverId != request.auth.uid\n        && data.conversationId == conversationIdFor(data.senderId, data.receiverId)\n        && data.text is string\n        && hasMessageBody(data)\n        && validMentions(data)\n        && validAttachments(data)\n        && data.timestamp is timestamp;\n    }\n\n    function canCreateChannelMessage(data) {\n      return isChannelMessage(data)\n        && data.senderId == request.auth.uid\n        && data.channelId is string\n        && channelExists(data.channelId)\n        && canReadChannelDoc(\n          data.channelId,\n          channelDoc(data.channelId).data\n        )\n        && data.text is string\n        && hasMessageBody(data)\n        && validMentions(data)\n        && validAttachments(data)\n        && data.timestamp is timestamp;\n    }\n\n    function messageCoreFieldsUnchanged() {\n      return request.resource.data.senderId == resource.data.senderId\n        && request.resource.data.timestamp == resource.data.timestamp\n        && (\n          (\n            hasField(resource.data, 'channelId')\n            && request.resource.data.channelId == resource.data.channelId\n          )\n          || (\n            hasField(resource.data, 'receiverId')\n            && hasField(resource.data, 'conversationId')\n            && request.resource.data.receiverId == resource.data.receiverId\n            && request.resource.data.conversationId == resource.data.conversationId\n          )\n        );\n    }\n\n    function canUpdateMessage() {\n      return canReadMessage(resource.data)\n        && messageCoreFieldsUnchanged()\n        && (\n          request.auth.uid == resource.data.senderId\n          || request.resource.data\n              .diff(resource.data)\n              .changedKeys()\n              .hasOnly(['reactions', 'read'])\n        );\n    }\n\n    match /users/{userId} {\n      allow read: if isSignedIn();\n      allow create: if isRegularUser() && request.auth.uid == userId;\n      allow update: if isRegularUser() && request.auth.uid == userId;\n      allow delete: if false;\n\n      match /inboxState/{contextId} {\n        allow read: if isRegularUser() && request.auth.uid == userId;\n        allow create, update: if isRegularUser()\n          && request.auth.uid == userId\n          && isValidInboxState(request.resource.data, contextId);\n        allow delete: if false;\n      }\n    }\n\n    match /channels/{channelId} {\n      allow get: if isSignedIn() && canReadChannelDoc(channelId, resource.data);\n\n      // Keep list rule query-compatible with: where('members', 'array-contains', request.auth.uid)\n      allow list: if isRegularUser()\n        && request.auth.uid in resource.data.members;\n\n      allow create: if isRegularUser()\n        && request.resource.data.createdBy == request.auth.uid\n        && validChannelRoleLists(request.resource.data)\n        && request.auth.uid in request.resource.data.members\n        && request.auth.uid in request.resource.data.admins;\n\n      allow update: if isRegularUser()\n        && (\n          canManageChannel(resource.data)\n          || (\n            isChannelMemberByData(resource.data)\n            && isMemberOnlyChannelUpdate()\n          )\n        )\n        && request.resource.data.createdBy == resource.data.createdBy\n        && validChannelRoleLists(request.resource.data);\n\n      allow delete: if isRegularUser() && canManageChannel(resource.data);\n    }\n\n    match /messages/{messageId} {\n      allow read: if isSignedIn() && canReadMessage(resource.data);\n\n      allow create: if isRegularUser()\n        && (\n          canCreateDirectMessage(request.resource.data)\n          || canCreateChannelMessage(request.resource.data)\n        );\n\n      allow update: if isRegularUser() && canUpdateMessage();\n      allow delete: if isRegularUser() && request.auth.uid == resource.data.senderId;\n\n      match /threads/{threadId} {\n        allow read: if isSignedIn() && canReadThreadParent(messageId);\n        allow create: if isRegularUser()\n          && canCreateThreadMessage(messageId, request.resource.data);\n        allow update, delete: if false;\n      }\n    }\n\n    match /{document=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-04-15T21:04:22.717295Z","metadata":{"services":["cloud.firestore"]}}
